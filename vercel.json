{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/auth/callback",
      "destination": "/index.html"
    },
    {
      "source": "/cafeteria",
      "destination": "/index.html"
    },
    {
      "source": "/cafeteria/",
      "destination": "/index.html"
    },
    {
      "source": "/reset-password",
      "destination": "/index.html"
    },
    {
      "source": "/reset-password/",
      "destination": "/index.html"
    }
  ]
}
